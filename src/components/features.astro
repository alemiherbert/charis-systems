---
import { Icon } from "astro-icon/components";

const services = [
  {
    title: "Frontend Development",
    description:
      "React, Vue, and Next.js development with a focus on performance and accessibility.",
    icon: "bx:bxs-devices",
    gradient: "from-blue-500 to-cyan-500",
  },
  {
    title: "Backend Development",
    description:
      "Scalable APIs and server solutions using Node.js, Python, or Go.",
    icon: "bx:bxs-data",
    gradient: "from-purple-500 to-pink-500",
  },
  {
    title: "Full Stack Solutions",
    description:
      "End-to-end development combining frontend and backend expertise.",
    icon: "bx:bxs-layer",
    gradient: "from-orange-500 to-red-500",
  },
  {
    title: "Code Review & Refactoring",
    description:
      "Optimize your codebase with expert review and best practices.",
    icon: "bx:bxs-file-find",
    gradient: "from-green-500 to-teal-500",
  },
  {
    title: "Data Science",
    description:
      "Advanced data analysis, machine learning, and predictive modeling.",
    icon: "bx:bx-bar-chart-square",
    gradient: "from-indigo-500 to-purple-500",
  },
  {
    title: "Integration & APIs",
    description:
      "Connect systems and automate workflows with seamless API integrations.",
    icon: "bx:bxs-plug",
    gradient: "from-pink-500 to-rose-500",
  },
];
---

<div class="mt-24 md:mt-0">
  <h2 class="text-4xl text-center lg:text-5xl font-bold lg:tracking-tight bg-gradient-to-r from-slate-900 to-slate-700 bg-clip-text text-transparent">
    Senior developers at your service
  </h2>
  <p class="text-lg text-center mt-4 text-slate-600 max-w-2xl mx-auto">
    We provide fast, reliable, and professional development services scaled to
    your needs.
  </p>
</div>

<div class="grid max-w-5xl mx-auto sm:grid-cols-2 md:grid-cols-3 mt-16 gap-8">
  {
    services.map((item) => (
      <div class="group p-6 rounded-2xl bg-white border border-slate-100 hover:border-slate-200 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
        <div class={`w-12 h-12 bg-gradient-to-br ${item.gradient} rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300`}>
          <Icon class="text-white w-6 h-6" name={item.icon} />
        </div>
        <h3 class="font-semibold text-lg text-slate-900">{item.title}</h3>
        <p class="text-slate-500 mt-2 leading-relaxed">{item.description}</p>
      </div>
    ))
  }
</div>
