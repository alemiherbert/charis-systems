---
// @ts-ignore
import { Icon } from "astro-icon/components";
---

<div class="mt-16 sm:mt-20 lg:mt-24 mb-8 sm:mb-10 px-4 sm:px-6 lg:px-0">
  <h2 class="text-3xl sm:text-4xl text-center lg:text-5xl font-bold lg:tracking-tight bg-gradient-to-r from-slate-900 to-slate-700 bg-clip-text text-transparent">
    Our Stack
  </h2>
  <p class="text-base sm:text-lg text-center mt-4 text-slate-600 max-w-2xl mx-auto">
    Here are some of our choice tools and weapons.
  </p>
  <div class="flex gap-4 sm:gap-6 md:gap-8 lg:gap-12 items-center justify-center mt-8 sm:mt-12 flex-wrap">
    <div class="group p-3 sm:p-4 rounded-2xl hover:bg-slate-50 transition-all duration-300">
      <Icon class="size-8 sm:size-10 md:size-12 text-blue-500 group-hover:scale-110 transition-transform duration-300" name="simple-icons:react" />
    </div>
    <div class="group p-3 sm:p-4 rounded-2xl hover:bg-slate-50 transition-all duration-300">
      <Icon class="size-8 sm:size-10 md:size-12 text-green-500 group-hover:scale-110 transition-transform duration-300" name="simple-icons:vuedotjs" />
    </div>
    <div class="group p-3 sm:p-4 rounded-2xl hover:bg-slate-50 transition-all duration-300">
      <Icon class="size-8 sm:size-10 md:size-12 text-black group-hover:scale-110 transition-transform duration-300" name="simple-icons:nextdotjs" />
    </div>
    <div class="group p-3 sm:p-4 rounded-2xl hover:bg-slate-50 transition-all duration-300">
      <Icon class="size-8 sm:size-10 md:size-12 text-blue-600 group-hover:scale-110 transition-transform duration-300" name="simple-icons:typescript" />
    </div>
    <div class="group p-3 sm:p-4 rounded-2xl hover:bg-slate-50 transition-all duration-300">
      <Icon class="size-8 sm:size-10 md:size-12 text-yellow-500 group-hover:scale-110 transition-transform duration-300" name="simple-icons:python" />
    </div>
    <div class="group p-3 sm:p-4 rounded-2xl hover:bg-slate-50 transition-all duration-300">
      <Icon class="size-8 sm:size-10 md:size-12 text-red-500 group-hover:scale-110 transition-transform duration-300" name="simple-icons:git" />
    </div>
    <div class="group p-3 sm:p-4 rounded-2xl hover:bg-slate-50 transition-all duration-300">
      <Icon class="size-8 sm:size-10 md:size-12 text-green-500 group-hover:scale-110 transition-transform duration-300" name="simple-icons:mongodb" />
    </div>
    <div class="group p-3 sm:p-4 rounded-2xl hover:bg-slate-50 transition-all duration-300">
      <Icon class="size-8 sm:size-10 md:size-12 text-cyan-400 group-hover:scale-110 transition-transform duration-300" name="simple-icons:tailwindcss" />
    </div>
    <div class="group p-3 sm:p-4 rounded-2xl hover:bg-slate-50 transition-all duration-300">
      <Icon class="size-8 sm:size-10 md:size-12 text-green-600 group-hover:scale-110 transition-transform duration-300" name="simple-icons:pandas" />
    </div>
  </div>
</div>

