---
import { Icon } from "astro-icon/components";
export const testimonials = [
  {
    quote:
      "We now get 10x the traffic before we met these guys. Definitely hiring them again.",
    name: "Joshua Masiiko",
    position: "CEO, Kanyeihamba Agriculture",
  },
  {
    quote:
      "Their designs are masterfully polished, trend yet remaining distincltly original.",
    name: "Jonathan Mageno",
    position: "CTO, The Kampala Journal",
  },
  {
    quote:
      "Highly recommend! We had to ship an app in 2 weeks. These guys did it in 5 days.",
    name: "Emily Zhang",
    position: "Marketing Director, Phire",
  },
];
---

<section class="py-12 sm:py-16 lg:py-20 px-4 sm:px-6 lg:px-0" id="testimonials">
  <div class="container mx-auto max-w-5xl text-center">
    <h2 class="text-3xl sm:text-4xl text-center lg:text-5xl font-bold lg:tracking-tight bg-gradient-to-r from-slate-900 to-slate-700 bg-clip-text text-transparent">
      Our Reputation
    </h2>
    <p class="text-base sm:text-lg text-slate-600 mt-4 max-w-2xl mx-auto">
      Hear from our satisfied clients.
    </p>

    <div class="mt-8 sm:mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
      {
        testimonials.map((testimonial) => (
          <div class="group bg-white rounded-2xl p-6 sm:p-8 text-center border border-slate-100 hover:border-slate-200 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <div class="w-10 h-10 sm:w-12 sm:h-12 mx-auto mb-4 sm:mb-6 rounded-full bg-gradient-to-br from-indigo-100 to-purple-100 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
              <Icon
                name="bx:bxs-quote-alt-left"
                class="text-lg sm:text-xl text-indigo-500"
              />
            </div>
            <p class="text-slate-600 leading-relaxed text-sm sm:text-base">{testimonial.quote}</p>
            <div class="mt-4 sm:mt-6 pt-4 sm:pt-6 border-t border-slate-100">
              <p class="font-semibold text-slate-900 text-sm sm:text-base">{testimonial.name}</p>
              <p class="text-xs sm:text-sm text-slate-500 mt-1">{testimonial.position}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
