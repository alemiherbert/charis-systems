---
import Link from "./ui/link.astro";
---

<div class="relative bg-gradient-to-br from-indigo-600 via-purple-600 to-indigo-700 p-6 sm:p-8 md:px-16 lg:px-20 md:py-16 lg:py-20 mt-12 sm:mt-16 lg:mt-20 mx-4 sm:mx-auto max-w-5xl rounded-2xl sm:rounded-3xl flex flex-col items-center text-center overflow-hidden shadow-2xl shadow-indigo-500/25">
  <!-- Decorative elements -->
  <div class="absolute top-0 left-0 w-32 sm:w-48 md:w-64 h-32 sm:h-48 md:h-64 bg-white/10 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
  <div class="absolute bottom-0 right-0 w-40 sm:w-60 md:w-80 h-40 sm:h-60 md:h-80 bg-purple-400/20 rounded-full blur-3xl translate-x-1/3 translate-y-1/3"></div>
  
  <h2 class="text-white text-2xl sm:text-3xl md:text-4xl lg:text-6xl tracking-tight font-bold relative z-10">
    Let's build your idea.
  </h2>
  <p class="text-indigo-100 mt-3 sm:mt-4 text-base sm:text-lg md:text-xl max-w-2xl relative z-10">
    Turn your vision into reality with our expertise.
  </p>
  <div class="flex mt-6 sm:mt-8 relative z-10">
    <Link href="/contact" style="inverted" class="px-6 sm:px-8 py-2.5 sm:py-3 rounded-lg sm:rounded-xl font-semibold shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-105 text-sm sm:text-base">Get Started</Link>
  </div>
</div>
