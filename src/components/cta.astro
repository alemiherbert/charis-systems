---
import Link from "./ui/link.astro";
---

<div class="relative bg-gradient-to-br from-indigo-600 via-purple-600 to-indigo-700 p-8 md:px-20 md:py-20 mt-20 mx-auto max-w-5xl rounded-3xl flex flex-col items-center text-center overflow-hidden shadow-2xl shadow-indigo-500/25">
  <!-- Decorative elements -->
  <div class="absolute top-0 left-0 w-64 h-64 bg-white/10 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
  <div class="absolute bottom-0 right-0 w-80 h-80 bg-purple-400/20 rounded-full blur-3xl translate-x-1/3 translate-y-1/3"></div>
  
  <h2 class="text-white text-4xl md:text-6xl tracking-tight font-bold relative z-10">
    Let's build your idea.
  </h2>
  <p class="text-indigo-100 mt-4 text-lg md:text-xl max-w-2xl relative z-10">
    Turn your vision into reality with our expertise.
  </p>
  <div class="flex mt-8 relative z-10">
    <Link href="/contact" style="inverted" class="px-8 py-3 rounded-xl font-semibold shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-105">Get Started</Link>
  </div>
</div>
