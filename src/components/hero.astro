---
import Link from "@components/ui/link.astro";
import { Icon } from "astro-icon/components";
---

<main
  class="relative grid lg:grid-cols-2 bg-gradient-to-br from-indigo-50 via-white to-purple-50 px-4 sm:px-8 lg:px-12 place-items-center pt-12 pb-12 sm:pt-16 sm:pb-16 rounded-2xl mb-16 md:pt-16 md:pb-20 overflow-hidden min-h-[500px] md:min-h-[600px]"
>
  <!-- Decorative elements -->
  <div class="absolute top-0 right-0 w-48 sm:w-72 h-48 sm:h-72 bg-gradient-to-br from-indigo-200/30 to-purple-200/30 rounded-full blur-3xl -z-10"></div>
  <div class="absolute bottom-0 left-0 w-40 sm:w-64 h-40 sm:h-64 bg-gradient-to-tr from-blue-200/20 to-indigo-200/20 rounded-full blur-3xl -z-10"></div>
  
  <!-- Three.js Canvas Container -->
  <div class="py-6 md:order-1 hidden md:flex items-center justify-center w-full h-full min-h-[300px] lg:min-h-[400px]">
    <div id="three-canvas-container" class="w-full h-full relative">
      <canvas id="hero-canvas" class="w-full h-full"></canvas>
    </div>
  </div>
  
  <!-- Mobile animated shapes fallback -->
  <div class="md:hidden py-6 flex items-center justify-center">
    <div class="relative w-64 h-64">
      <div class="absolute inset-0 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-3xl animate-float opacity-80"></div>
      <div class="absolute inset-4 bg-gradient-to-tr from-cyan-400 to-indigo-500 rounded-2xl animate-float opacity-70" style="animation-delay: -2s;"></div>
      <div class="absolute inset-8 bg-gradient-to-r from-purple-400 to-pink-500 rounded-xl animate-float opacity-60" style="animation-delay: -4s;"></div>
      <div class="absolute inset-0 flex items-center justify-center">
        <Icon class="w-20 h-20 text-white drop-shadow-lg" name="bx:bxs-rocket" />
      </div>
    </div>
  </div>
  
  <div class="text-center md:text-left">
    <h1
      class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold lg:tracking-tight xl:tracking-tighter bg-gradient-to-r from-slate-900 via-indigo-900 to-slate-800 bg-clip-text text-transparent leading-tight"
    >
      Expert Tech Solutions on Demand
    </h1>
    <p class="text-base sm:text-lg mt-4 text-slate-600 max-w-xl leading-relaxed mx-auto md:mx-0">
      Web design, development, ERP implementation, and consulting — all with predictable monthly pricing and unlimited requests.
    </p>
    <div class="mt-6 sm:mt-8 flex flex-col sm:flex-row gap-3 justify-center md:justify-start">
      <Link
        size="lg"
        rel="noopener"
        href="/contact"
        class="flex gap-2 items-center bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 justify-center border-0 px-6 py-3 rounded-lg shadow-lg shadow-indigo-500/25 hover:shadow-xl hover:shadow-indigo-500/30 transition-all duration-300"
      >
        <Icon class="w-5 h-5" name="bx:bxs-envelope" />
        Contact Us
      </Link>
    </div>
  </div>
</main>

<script>
  import * as THREE from 'three';

  function initThreeJS() {
    const container = document.getElementById('three-canvas-container');
    const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
    
    if (!container || !canvas) return;

    // Check for WebGL support
    try {
      const testCanvas = document.createElement('canvas');
      const gl = testCanvas.getContext('webgl') || testCanvas.getContext('experimental-webgl');
      if (!gl) {
        console.warn('WebGL not supported, falling back to CSS animations');
        return;
      }
    } catch (e) {
      console.warn('WebGL check failed:', e);
      return;
    }

    // Scene setup
    const scene = new THREE.Scene();
    
    // Camera
    const camera = new THREE.PerspectiveCamera(75, container.clientWidth / container.clientHeight, 0.1, 1000);
    camera.position.z = 5;

    // Renderer
    let renderer: THREE.WebGLRenderer;
    try {
      renderer = new THREE.WebGLRenderer({ 
        canvas, 
        alpha: true, 
        antialias: true 
      });
      renderer.setSize(container.clientWidth, container.clientHeight);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    } catch (e) {
      console.warn('WebGL renderer creation failed:', e);
      return;
    }

    // Create floating geometric shapes
    const shapes: THREE.Mesh[] = [];
    const geometries: THREE.BufferGeometry[] = [];
    const materials: THREE.Material[] = [];
    
    const geometryConfigs = [
      () => new THREE.IcosahedronGeometry(0.8, 0),
      () => new THREE.OctahedronGeometry(0.6, 0),
      () => new THREE.TorusGeometry(0.5, 0.2, 16, 32),
      () => new THREE.DodecahedronGeometry(0.5, 0),
      () => new THREE.TetrahedronGeometry(0.6, 0),
    ];

    const colors = [0x6366f1, 0x8b5cf6, 0x06b6d4, 0xec4899, 0x3b82f6];

    geometryConfigs.forEach((createGeometry, i) => {
      const geometry = createGeometry();
      geometries.push(geometry);
      
      const material = new THREE.MeshPhongMaterial({
        color: colors[i],
        transparent: true,
        opacity: 0.8,
        shininess: 100,
        wireframe: i % 2 === 0 ? false : true,
      });
      materials.push(material);
      
      const mesh = new THREE.Mesh(geometry, material);
      mesh.position.x = (Math.random() - 0.5) * 6;
      mesh.position.y = (Math.random() - 0.5) * 4;
      mesh.position.z = (Math.random() - 0.5) * 3;
      mesh.userData = {
        rotationSpeed: {
          x: (Math.random() - 0.5) * 0.02,
          y: (Math.random() - 0.5) * 0.02,
        },
        floatSpeed: Math.random() * 0.5 + 0.5,
        floatOffset: Math.random() * Math.PI * 2,
        originalY: mesh.position.y,
      };
      shapes.push(mesh);
      scene.add(mesh);
    });

    // Lighting
    const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);
    scene.add(ambientLight);

    const directionalLight = new THREE.DirectionalLight(0xffffff, 1);
    directionalLight.position.set(5, 5, 5);
    scene.add(directionalLight);

    const pointLight = new THREE.PointLight(0x6366f1, 1, 10);
    pointLight.position.set(-3, 2, 3);
    scene.add(pointLight);

    // Animation with visibility check
    let time = 0;
    let animationId: number;
    let isVisible = true;

    // Intersection Observer for visibility-based animation
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        isVisible = entry.isIntersecting;
      });
    }, { threshold: 0.1 });
    
    observer.observe(container);

    function animate() {
      animationId = requestAnimationFrame(animate);
      
      // Only render when visible
      if (!isVisible) return;
      
      time += 0.01;

      shapes.forEach((shape) => {
        shape.rotation.x += shape.userData.rotationSpeed.x;
        shape.rotation.y += shape.userData.rotationSpeed.y;
        shape.position.y = shape.userData.originalY + Math.sin(time * shape.userData.floatSpeed + shape.userData.floatOffset) * 0.3;
      });

      renderer.render(scene, camera);
    }

    animate();

    // Handle resize
    function handleResize() {
      if (!container) return;
      camera.aspect = container.clientWidth / container.clientHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(container.clientWidth, container.clientHeight);
    }

    window.addEventListener('resize', handleResize);

    // Mouse interaction
    function handleMouseMove(event: MouseEvent) {
      const rect = container.getBoundingClientRect();
      const mouseX = ((event.clientX - rect.left) / rect.width) * 2 - 1;
      const mouseY = -((event.clientY - rect.top) / rect.height) * 2 + 1;
      
      camera.position.x = mouseX * 0.5;
      camera.position.y = mouseY * 0.5;
      camera.lookAt(scene.position);
    }

    container.addEventListener('mousemove', handleMouseMove);

    // Cleanup function
    function cleanup() {
      cancelAnimationFrame(animationId);
      observer.disconnect();
      window.removeEventListener('resize', handleResize);
      container.removeEventListener('mousemove', handleMouseMove);
      
      // Dispose Three.js resources
      shapes.forEach((mesh) => {
        scene.remove(mesh);
      });
      geometries.forEach((geometry) => geometry.dispose());
      materials.forEach((material) => material.dispose());
      renderer.dispose();
    }

    // Cleanup on page unload
    window.addEventListener('beforeunload', cleanup);
    
    // Also cleanup when navigating away (for SPA behavior)
    document.addEventListener('astro:before-swap', cleanup);
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initThreeJS);
  } else {
    initThreeJS();
  }
</script>
