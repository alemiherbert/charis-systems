---
import { Picture } from "astro:assets";
import heroImage from "assets/hero.png";
import Link from "@components/ui/link.astro";
import { Icon } from "astro-icon/components";
---

<main
  class="relative grid lg:grid-cols-2 bg-gradient-to-br from-indigo-50 via-white to-purple-50 px-8 lg:px-12 place-items-center pt-16 pb-16 rounded-2xl mb-16 md:pt-16 md:pb-20 overflow-hidden"
>
  <!-- Decorative elements -->
  <div class="absolute top-0 right-0 w-72 h-72 bg-gradient-to-br from-indigo-200/30 to-purple-200/30 rounded-full blur-3xl -z-10"></div>
  <div class="absolute bottom-0 left-0 w-64 h-64 bg-gradient-to-tr from-blue-200/20 to-indigo-200/20 rounded-full blur-3xl -z-10"></div>
  
  <div class="py-6 md:order-1 hidden md:block">
    <Picture
      src={heroImage}
      alt="Developer working on code"
      widths={[200, 400, 600]}
      sizes="(max-width: 800px) 100vw, 620px"
      loading="eager"
      format="avif"
      class="drop-shadow-xl hover:scale-105 transition-transform duration-500"
    />
  </div>
  <div>
    <h1
      class="text-5xl lg:text-6xl xl:text-7xl font-bold lg:tracking-tight xl:tracking-tighter bg-gradient-to-r from-slate-900 via-indigo-900 to-slate-800 bg-clip-text text-transparent"
    >
      Get Expert Devs on Demand
    </h1>
    <p class="text-lg mt-4 text-slate-600 max-w-xl leading-relaxed">
      Get an expert product team with predictable monthly pricing and unlimited development requests.
    </p>
    <div class="mt-8 flex flex-col sm:flex-row gap-3">
      <Link
        size="lg"
        rel="noopener"
        href="/contact"
        class="flex gap-2 items-center bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 justify-center border-0 px-6 py-3 rounded-lg shadow-lg shadow-indigo-500/25 hover:shadow-xl hover:shadow-indigo-500/30 transition-all duration-300"
      >
        <Icon class="w-5 h-5" name="bx:bxs-envelope" />
        Contact Us
      </Link>
    </div>
  </div>
</main>
