---
import '@fontsource-variable/space-grotesk';
import '@fontsource/geist-sans/400.css';
import '@fontsource/geist-sans/500.css';
import '@fontsource/geist-sans/600.css';
import '@fontsource/geist-sans/700.css';
import '@fontsource/geist-sans/800.css';
import '@fontsource/geist-sans/900.css';
---

<style is:inline>
  :root {
    /* Fonts: Space Grotesk for headings, Geist for body */
    --aw-font-sans: 'Geist Sans', sans-serif;
    --aw-font-serif: 'Geist Sans', serif;
    --aw-font-heading: 'Space Grotesk Variable', 'Space Grotesk', sans-serif;

    /* Original Purple/Indigo Palette with good contrast */
    --aw-color-primary: rgb(79 70 229);
    --aw-color-secondary: rgb(30 58 138);
    --aw-color-accent: rgb(109 40 217);

    --aw-color-text-heading: rgb(30 41 59);
    --aw-color-text-default: rgb(51 65 85);
    --aw-color-text-muted: rgb(100 116 139);
    --aw-color-bg-page: rgb(255 255 255);

    --aw-color-bg-page-dark: rgb(15 23 42);

    ::selection {
      background-color: rgb(79 70 229);
      color: white;
    }
  }

  .dark {
    --aw-font-sans: 'Geist Sans', sans-serif;
    --aw-font-serif: 'Geist Sans', serif;
    --aw-font-heading: 'Space Grotesk Variable', 'Space Grotesk', sans-serif;

    --aw-color-primary: rgb(129 140 248);
    --aw-color-secondary: rgb(96 165 250);
    --aw-color-accent: rgb(167 139 250);

    --aw-color-text-heading: rgb(248 250 252);
    --aw-color-text-default: rgb(226 232 240);
    --aw-color-text-muted: rgb(148 163 184);
    --aw-color-bg-page: rgb(15 23 42);

    ::selection {
      background-color: rgb(129 140 248);
      color: black;
    }
  }

  /* Brutalist Design: No rounded corners */
  * {
    border-radius: 0 !important;
  }

  /* Strong borders for brutalist aesthetic */
  .btn, button, .card, .box {
    border: 2px solid currentColor;
  }
</style>
