---
import '@fontsource-variable/space-grotesk';
import '@fontsource/geist-sans/400.css';
import '@fontsource/geist-sans/500.css';
import '@fontsource/geist-sans/600.css';
import '@fontsource/geist-sans/700.css';
import '@fontsource/geist-sans/800.css';
import '@fontsource/geist-sans/900.css';
---

<style is:inline>
  :root {
    /* Fonts: Geist for headings, Space Grotesk for body */
    --aw-font-sans: 'Space Grotesk Variable', 'Space Grotesk', sans-serif;
    --aw-font-serif: 'Space Grotesk Variable', 'Space Grotesk', serif;
    --aw-font-heading: 'Geist Sans', sans-serif;

    /* Brutalist Color Palette - Darker variants for better readability */
    /* Primary: Cornflower Blue - using darker shade for text */
    /* Secondary: Dark Sea Green - using darker shade for text */
    /* Accent: Coral/Salmon */
    /* Dark: Charcoal */
    
    --aw-color-primary: rgb(58 117 232);
    --aw-color-secondary: rgb(85 137 85);
    --aw-color-accent: rgb(220 100 90);

    --aw-color-text-heading: rgb(17 17 17);
    --aw-color-text-default: rgb(33 33 33);
    --aw-color-text-muted: rgb(75 75 75);
    --aw-color-bg-page: rgb(255 255 255);

    --aw-color-bg-page-dark: rgb(17 17 17);

    ::selection {
      background-color: rgb(58 117 232);
      color: white;
    }
  }

  .dark {
    --aw-font-sans: 'Space Grotesk Variable', 'Space Grotesk', sans-serif;
    --aw-font-serif: 'Space Grotesk Variable', 'Space Grotesk', serif;
    --aw-font-heading: 'Geist Sans', sans-serif;

    --aw-color-primary: rgb(130 170 255);
    --aw-color-secondary: rgb(160 210 160);
    --aw-color-accent: rgb(255 150 140);

    --aw-color-text-heading: rgb(250 250 250);
    --aw-color-text-default: rgb(229 229 229);
    --aw-color-text-muted: rgb(180 180 180);
    --aw-color-bg-page: rgb(17 17 17);

    ::selection {
      background-color: rgb(130 170 255);
      color: black;
    }
  }

  /* Brutalist Design: No rounded corners */
  * {
    border-radius: 0 !important;
  }

  /* Strong borders for brutalist aesthetic */
  .btn, button, .card, .box {
    border: 2px solid currentColor;
  }
</style>
