---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Charis Systems — Expert Tech Solutions on Demand',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Get Started',
        href: '/contact',
        icon: 'tabler:arrow-right',
      },
      { text: 'Our Services', href: '/services' },
    ]}
  >
    <Fragment slot="title">
      <span class="text-primary">Expert Tech</span><br />
      Solutions on Demand
    </Fragment>

    <Fragment slot="subtitle">
      Web design, development, ERP implementation, and consulting — all with 
      <span class="font-bold text-accent">predictable monthly pricing</span> and unlimited requests.
      No hiring headaches. No long-term commitments.
    </Fragment>

    <Fragment slot="image">
      <div id="hero-animation" class="w-full h-[400px] lg:h-[500px] relative border-4 border-slate-800 bg-gradient-to-br from-indigo-50 to-purple-50 dark:from-slate-900 dark:to-indigo-950">
        <canvas id="hero-canvas" class="w-full h-full"></canvas>
      </div>
      <script>
        import * as THREE from 'three';

        function initThreeJS() {
          const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
          const container = document.getElementById('hero-animation');
          
          if (!canvas || !container) return;

          try {
            const testCanvas = document.createElement('canvas');
            const gl = testCanvas.getContext('webgl') || testCanvas.getContext('experimental-webgl');
            if (!gl) return;
          } catch (e) { return; }

          const scene = new THREE.Scene();
          const camera = new THREE.PerspectiveCamera(75, container.clientWidth / container.clientHeight, 0.1, 1000);
          camera.position.z = 5;

          let renderer: THREE.WebGLRenderer;
          try {
            renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
            renderer.setSize(container.clientWidth, container.clientHeight);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
          } catch (e) { return; }

          const shapes: THREE.Mesh[] = [];
          const geometries: THREE.BufferGeometry[] = [];
          const materials: THREE.Material[] = [];
          
          // Brutalist geometric shapes - sharp edges only
          const geometryConfigs = [
            () => new THREE.BoxGeometry(1, 1, 1),
            () => new THREE.BoxGeometry(0.8, 1.5, 0.8),
            () => new THREE.BoxGeometry(1.2, 0.6, 1.2),
            () => new THREE.TetrahedronGeometry(0.8, 0),
            () => new THREE.OctahedronGeometry(0.7, 0),
          ];

          // Purple/Indigo gradient colors
          const colors = [0x4F46E5, 0x7C3AED, 0x8B5CF6, 0x6366F1, 0xA855F7];

          geometryConfigs.forEach((createGeometry, i) => {
            const geometry = createGeometry();
            geometries.push(geometry);
            
            const material = new THREE.MeshPhongMaterial({
              color: colors[i],
              transparent: true,
              opacity: 0.9,
              shininess: 30,
              flatShading: true, // Brutalist flat shading
            });
            materials.push(material);
            
            const mesh = new THREE.Mesh(geometry, material);
            mesh.position.x = (Math.random() - 0.5) * 6;
            mesh.position.y = (Math.random() - 0.5) * 4;
            mesh.position.z = (Math.random() - 0.5) * 3;
            mesh.userData = {
              rotationSpeed: { x: (Math.random() - 0.5) * 0.015, y: (Math.random() - 0.5) * 0.015 },
              floatSpeed: Math.random() * 0.3 + 0.3,
              floatOffset: Math.random() * Math.PI * 2,
              originalY: mesh.position.y,
            };
            shapes.push(mesh);
            scene.add(mesh);
          });

          // Add wireframe cubes for brutalist effect
          for (let i = 0; i < 3; i++) {
            const wireGeometry = new THREE.BoxGeometry(1.5, 1.5, 1.5);
            const wireMaterial = new THREE.MeshBasicMaterial({
              color: 0x4F46E5,
              wireframe: true,
              transparent: true,
              opacity: 0.4,
            });
            const wireMesh = new THREE.Mesh(wireGeometry, wireMaterial);
            wireMesh.position.x = (Math.random() - 0.5) * 5;
            wireMesh.position.y = (Math.random() - 0.5) * 3;
            wireMesh.position.z = (Math.random() - 0.5) * 2;
            wireMesh.userData = {
              rotationSpeed: { x: 0.005, y: 0.005 },
              floatSpeed: 0.2,
              floatOffset: Math.random() * Math.PI * 2,
              originalY: wireMesh.position.y,
            };
            shapes.push(wireMesh);
            scene.add(wireMesh);
          }

          const ambientLight = new THREE.AmbientLight(0xffffff, 0.5);
          scene.add(ambientLight);

          const directionalLight = new THREE.DirectionalLight(0xffffff, 1);
          directionalLight.position.set(5, 5, 5);
          scene.add(directionalLight);

          let time = 0;
          let animationId: number;
          let isVisible = true;

          const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => { isVisible = entry.isIntersecting; });
          }, { threshold: 0.1 });
          
          observer.observe(container);

          function animate() {
            animationId = requestAnimationFrame(animate);
            if (!isVisible) return;
            time += 0.01;

            shapes.forEach((shape) => {
              shape.rotation.x += shape.userData.rotationSpeed.x;
              shape.rotation.y += shape.userData.rotationSpeed.y;
              shape.position.y = shape.userData.originalY + Math.sin(time * shape.userData.floatSpeed + shape.userData.floatOffset) * 0.2;
            });

            renderer.render(scene, camera);
          }

          animate();

          function handleResize() {
            if (!container) return;
            camera.aspect = container.clientWidth / container.clientHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(container.clientWidth, container.clientHeight);
          }

          window.addEventListener('resize', handleResize);

          function handleMouseMove(event: MouseEvent) {
            const rect = container.getBoundingClientRect();
            const mouseX = ((event.clientX - rect.left) / rect.width) * 2 - 1;
            const mouseY = -((event.clientY - rect.top) / rect.height) * 2 + 1;
            camera.position.x = mouseX * 0.3;
            camera.position.y = mouseY * 0.3;
            camera.lookAt(scene.position);
          }

          container.addEventListener('mousemove', handleMouseMove);

          function cleanup() {
            cancelAnimationFrame(animationId);
            observer.disconnect();
            window.removeEventListener('resize', handleResize);
            container.removeEventListener('mousemove', handleMouseMove);
            shapes.forEach((mesh) => { scene.remove(mesh); });
            geometries.forEach((geometry) => geometry.dispose());
            materials.forEach((material) => material.dispose());
            renderer.dispose();
          }

          window.addEventListener('beforeunload', cleanup);
          document.addEventListener('astro:before-swap', cleanup);
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initThreeJS);
        } else {
          initThreeJS();
        }
      </script>
    </Fragment>
  </Hero>

  <!-- Features Widget -->
  <Features
    id="services"
    tagline="SERVICES"
    title="What We Build"
    subtitle="From web design to ERP implementation, we deliver fast, reliable, and professional services."
    items={[
      {
        title: 'Web Design',
        description: 'Bold, functional websites that convert visitors into customers.',
        icon: 'tabler:palette',
      },
      {
        title: 'Full Stack Development',
        description: 'End-to-end applications with React, Vue, Next.js, and Node.js.',
        icon: 'tabler:code',
      },
      {
        title: 'ERP Implementation',
        description: 'Enterprise resource planning systems deployed and customized.',
        icon: 'tabler:settings-automation',
      },
      {
        title: 'ERP Consulting',
        description: 'Strategic guidance to maximize your ERP investment.',
        icon: 'tabler:briefcase',
      },
      {
        title: 'Data Science',
        description: 'Advanced analytics, machine learning, and predictive modeling.',
        icon: 'tabler:chart-bar',
      },
      {
        title: 'Integration & APIs',
        description: 'Connect systems and automate workflows seamlessly.',
        icon: 'tabler:plug',
      },
    ]}
  />

  <!-- Content Widget -->
  <Content
    isReversed
    tagline="WHY US"
    title="Your Dedicated Tech Partner"
    items={[
      {
        title: 'Predictable Pricing',
        description: 'Fixed monthly rates. No surprises. Unlimited requests.',
      },
      {
        title: 'Fast Turnaround',
        description: 'Most requests completed in 2-3 business days.',
      },
      {
        title: 'Senior Expertise',
        description: 'Work with experienced developers who understand enterprise needs.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Team collaboration',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2 font-heading">Built for Growth</h3>
      Scale your tech capabilities without the overhead of hiring.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-seagreen/10 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget -->
  <Steps
    title="How It Works"
    items={[
      {
        title: '01. <span class="font-bold">Subscribe</span>',
        description: 'Choose a plan. Cancel or pause anytime.',
        icon: 'tabler:credit-card',
      },
      {
        title: '02. <span class="font-bold">Request</span>',
        description: 'Submit your requests. We handle one at a time with focus.',
        icon: 'tabler:list-check',
      },
      {
        title: '03. <span class="font-bold">Review</span>',
        description: 'Receive work within days. Revise until satisfied.',
        icon: 'tabler:eye',
      },
      {
        title: '04. <span class="font-bold">Repeat</span>',
        description: 'Keep requests coming. We are your dedicated team.',
        icon: 'tabler:refresh',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1616198814651-e71f960c3180?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=987&q=80',
      alt: 'Process steps',
    }}
  />

  <!-- Stats Widget -->
  <Stats
    stats={[
      { title: 'Projects', amount: '150+' },
      { title: 'Clients', amount: '50+' },
      { title: 'Years', amount: '8+' },
      { title: 'Technologies', amount: '25+' },
    ]}
  />

  <!-- FAQs Widget -->
  <FAQs
    title="FAQ"
    subtitle="Common questions answered"
    tagline="QUESTIONS"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'How does the subscription work?',
        description: 'Choose a plan, submit unlimited requests. We work on them one at a time. Predictable costs, no surprises.',
      },
      {
        title: 'What if I am not satisfied?',
        description: 'Unlimited revisions until you are 100% happy. Your satisfaction is guaranteed.',
      },
      {
        title: 'How fast is delivery?',
        description: 'Most requests completed in 2-3 business days. Complex projects may take longer.',
      },
      {
        title: 'Can I pause or cancel?',
        description: 'Yes. Pause when you need a break, cancel anytime. No questions asked.',
      },
    ]}
  />

  <!-- CallToAction Widget -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Start Building →',
        href: '/contact',
      },
    ]}
  >
    <Fragment slot="title">
      Ready to Build?
    </Fragment>

    <Fragment slot="subtitle">
      Get started today. No commitment required.
    </Fragment>
  </CallToAction>
</Layout>
