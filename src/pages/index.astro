                    ║  │                                                      │  ║
                    ║  └──────────────────────────────────────────────────────┘  ║
                    ║════════════════════════════════════════════════════════════║
                    ╚══════════════════════════════════════════════════════════════╝
                         ╔══════════════════════════════════════════════════════╗
                         ║░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░║
                         ╚══════════════════════════════════════════════════════╝
`
          ];

          let currentFrame = 0;
          let animationId: number;
          let isVisible = true;

          const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => { isVisible = entry.isIntersecting; });
          }, { threshold: 0.1 });
          
          observer.observe(container);

          function animate() {
            if (isVisible) {
              container.textContent = laptopFrames[currentFrame];
              currentFrame = (currentFrame + 1) % laptopFrames.length;
            }
            animationId = setTimeout(animate, 800);
          }

          animate();

          function cleanup() {
            clearTimeout(animationId);
            observer.disconnect();
          }

          window.addEventListener('beforeunload', cleanup);
          document.addEventListener('astro:before-swap', cleanup);
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initAsciiAnimation);
        } else {
          initAsciiAnimation();
        }
      </script>
    </Fragment>

    <Fragment slot="title">
      <span class="text-primary">Expert Tech</span><br />
      Solutions on Demand
    </Fragment>

    <Fragment slot="subtitle">
      Web design, development, ERP implementation, and consulting — all with 
      <span class="font-bold text-accent">predictable monthly pricing</span> and unlimited requests.
      No hiring headaches. No long-term commitments.
    </Fragment>
