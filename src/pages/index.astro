---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Charis Systems — Expert Tech Solutions on Demand',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget with ASCII Laptop Background -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Get Started',
        href: '/contact',
        icon: 'tabler:arrow-right',
      },
      { text: 'Our Services', href: '/services' },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 overflow-hidden">
        <pre id="ascii-laptop" class="absolute inset-0 flex items-center justify-center text-indigo-300/30 dark:text-indigo-500/20 font-mono text-[6px] sm:text-[8px] md:text-[10px] lg:text-[12px] leading-none whitespace-pre select-none pointer-events-none" aria-hidden="true"></pre>
      </div>
      <script>
        function initAsciiAnimation() {
          const container = document.getElementById('ascii-laptop');
          if (!container) return;

          // ASCII laptop frames for animation
          const laptopFrames = [
            // Frame 1 - Screen content variation 1
`
