---
import Layout from '~/layouts/PageLayout.astro';

import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Button from '~/components/ui/Button.astro';

const metadata = {
  title: 'Charis Systems — Expert Tech Solutions on Demand',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Custom Hero with 3D Solar System Animation -->
  <section class="relative md:-mt-[76px] not-prose min-h-[80vh] overflow-hidden">
    <!-- Background gradient -->
    <div class="absolute inset-0 bg-gradient-to-br from-slate-50 via-indigo-50/30 to-purple-50/20 dark:from-slate-900 dark:via-indigo-950/30 dark:to-purple-950/20"></div>
    
    <!-- Three.js Solar System Container - positioned to the right -->
    <div id="solar-system-container" class="absolute right-0 top-0 w-[60vw] h-full pointer-events-none" aria-hidden="true"></div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
      <div class="pt-0 md:pt-[76px]"></div>
      <div class="py-12 md:py-20 lg:py-28">
        <!-- Text content - positioned to the left -->
        <div class="max-w-2xl text-left pb-10 md:pb-16">
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold leading-tighter tracking-tighter mb-6 font-heading dark:text-gray-200">
            <span class="text-primary">Expert Tech</span><br />
            Solutions on Demand
          </h1>
          <p class="text-xl text-muted mb-8 dark:text-slate-300 max-w-xl">
            Web design, development, ERP implementation, and consulting — all with 
            <span class="font-bold text-accent">predictable monthly pricing</span> and unlimited requests.
            No hiring headaches. No long-term commitments.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <Button variant="primary" text="Get Started" href="/contact" icon="tabler:arrow-right" />
            <Button text="Our Services" href="/services" />
          </div>
        </div>
      </div>
    </div>
    
    <script>
      async function initSolarSystem() {
        const container = document.getElementById('solar-system-container');
        if (!container) return;

        // Check for WebGL support
        const canvas = document.createElement('canvas');
        const gl = canvas.getContext('webgl') || canvas.getContext('experimental-webgl');
        if (!gl) {
          console.warn('WebGL not supported, skipping solar system animation');
          return;
        }

        // Dynamically import Three.js
        const THREE = await import('three');

        // Setup scene
        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(60, container.clientWidth / container.clientHeight, 0.1, 1000);
        camera.position.set(0, 15, 25);
        camera.lookAt(0, 0, 0);

        const renderer = new THREE.WebGLRenderer({ 
          antialias: true, 
          alpha: true,
          powerPreference: 'high-performance'
        });
        renderer.setSize(container.clientWidth, container.clientHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.setClearColor(0x000000, 0);
        container.appendChild(renderer.domElement);

        // Create Sun with glow effect
        const sunGeometry = new THREE.SphereGeometry(2.5, 32, 32);
        const sunMaterial = new THREE.MeshBasicMaterial({ 
          color: 0xfcd34d,
          transparent: true,
          opacity: 0.9
        });
        const sun = new THREE.Mesh(sunGeometry, sunMaterial);
        scene.add(sun);

        // Sun glow
        const sunGlowGeometry = new THREE.SphereGeometry(3.2, 32, 32);
        const sunGlowMaterial = new THREE.MeshBasicMaterial({ 
          color: 0xfbbf24,
          transparent: true,
          opacity: 0.3
        });
        const sunGlow = new THREE.Mesh(sunGlowGeometry, sunGlowMaterial);
        scene.add(sunGlow);

        // Planet data: [orbitRadius, planetSize, color, orbitSpeed, initialAngle]
        const planetData = [
          { orbit: 5, size: 0.4, color: 0x6366f1, speed: 1.5, angle: 0 },      // Mercury - Indigo
          { orbit: 7, size: 0.6, color: 0x8b5cf6, speed: 1.2, angle: 2.1 },    // Venus - Purple
          { orbit: 9.5, size: 0.7, color: 0x3b82f6, speed: 1.0, angle: 4.2 },  // Earth - Blue
          { orbit: 12, size: 0.5, color: 0xef4444, speed: 0.8, angle: 1.0 },   // Mars - Red
          { orbit: 16, size: 1.2, color: 0xf59e0b, speed: 0.5, angle: 3.5 },   // Jupiter - Orange
          { orbit: 20, size: 1.0, color: 0xa855f7, speed: 0.35, angle: 5.0 },  // Saturn - Violet
        ];

        interface Planet {
          mesh: THREE.Mesh;
          orbit: number;
          speed: number;
          angle: number;
          ring?: THREE.Mesh;
        }

        const planets: Planet[] = [];

        // Create planets and orbit rings
        planetData.forEach((data) => {
          // Orbit ring
          const orbitGeometry = new THREE.RingGeometry(data.orbit - 0.05, data.orbit + 0.05, 64);
          const orbitMaterial = new THREE.MeshBasicMaterial({ 
            color: 0x6366f1,
            transparent: true,
            opacity: 0.15,
            side: THREE.DoubleSide
          });
          const orbitRing = new THREE.Mesh(orbitGeometry, orbitMaterial);
          orbitRing.rotation.x = -Math.PI / 2;
          scene.add(orbitRing);

          // Planet
          const planetGeometry = new THREE.SphereGeometry(data.size, 24, 24);
          const planetMaterial = new THREE.MeshBasicMaterial({ 
            color: data.color,
            transparent: true,
            opacity: 0.85
          });
          const planet = new THREE.Mesh(planetGeometry, planetMaterial);
          scene.add(planet);

          const planetObj: Planet = {
            mesh: planet,
            orbit: data.orbit,
            speed: data.speed,
            angle: data.angle
          };

          // Add ring to Saturn (last planet)
          if (data.orbit === 20) {
            const ringGeometry = new THREE.RingGeometry(1.4, 2.0, 32);
            const ringMaterial = new THREE.MeshBasicMaterial({ 
              color: 0xc4b5fd,
              transparent: true,
              opacity: 0.6,
              side: THREE.DoubleSide
            });
            const ring = new THREE.Mesh(ringGeometry, ringMaterial);
            ring.rotation.x = Math.PI / 3;
            planetObj.ring = ring;
            scene.add(ring);
          }

          planets.push(planetObj);
        });

        // Add some stars in the background
        const starGeometry = new THREE.BufferGeometry();
        const starCount = 200;
        const starPositions = new Float32Array(starCount * 3);
        
        for (let i = 0; i < starCount * 3; i += 3) {
          starPositions[i] = (Math.random() - 0.5) * 100;
          starPositions[i + 1] = (Math.random() - 0.5) * 100;
          starPositions[i + 2] = (Math.random() - 0.5) * 100 - 20;
        }
        
        starGeometry.setAttribute('position', new THREE.BufferAttribute(starPositions, 3));
        const starMaterial = new THREE.PointsMaterial({ 
          color: 0x6366f1,
          size: 0.15,
          transparent: true,
          opacity: 0.5
        });
        const stars = new THREE.Points(starGeometry, starMaterial);
        scene.add(stars);

        let animationId: number;
        let isVisible = true;
        let mouseX = 0;
        let mouseY = 0;

        // Mouse movement for subtle camera interaction
        const handleMouseMove = (event: MouseEvent) => {
          mouseX = (event.clientX / window.innerWidth - 0.5) * 2;
          mouseY = (event.clientY / window.innerHeight - 0.5) * 2;
        };
        window.addEventListener('mousemove', handleMouseMove);

        // Intersection Observer for performance
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => { isVisible = entry.isIntersecting; });
        }, { threshold: 0.1 });
        observer.observe(container);

        // Handle window resize
        const handleResize = () => {
          camera.aspect = container.clientWidth / container.clientHeight;
          camera.updateProjectionMatrix();
          renderer.setSize(container.clientWidth, container.clientHeight);
        };
        window.addEventListener('resize', handleResize);

        // Animation loop
        function animate() {
          if (isVisible) {
            // Rotate sun glow
            sunGlow.rotation.y += 0.005;
            
            // Animate planets
            planets.forEach((planet) => {
              planet.angle += planet.speed * 0.01;
              planet.mesh.position.x = Math.cos(planet.angle) * planet.orbit;
              planet.mesh.position.z = Math.sin(planet.angle) * planet.orbit;
              planet.mesh.rotation.y += 0.02;
              
              // Update Saturn's ring position
              if (planet.ring) {
                planet.ring.position.copy(planet.mesh.position);
              }
            });

            // Subtle camera movement based on mouse
            camera.position.x = 0 + mouseX * 3;
            camera.position.y = 15 + mouseY * 2;
            camera.lookAt(0, 0, 0);

            // Rotate stars slowly
            stars.rotation.y += 0.0003;

            renderer.render(scene, camera);
          }
          animationId = requestAnimationFrame(animate);
        }

        animate();

        // Cleanup function
        function cleanup() {
          cancelAnimationFrame(animationId);
          observer.disconnect();
          window.removeEventListener('resize', handleResize);
          window.removeEventListener('mousemove', handleMouseMove);
          
          // Dispose Three.js resources
          scene.traverse((object) => {
            if (object instanceof THREE.Mesh) {
              object.geometry.dispose();
              if (object.material instanceof THREE.Material) {
                object.material.dispose();
              }
            }
          });
          renderer.dispose();
          
          if (container.contains(renderer.domElement)) {
            container.removeChild(renderer.domElement);
          }
        }

        window.addEventListener('beforeunload', cleanup);
        document.addEventListener('astro:before-swap', cleanup);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initSolarSystem);
      } else {
        initSolarSystem();
      }
    </script>
  </section>

  <!-- Features Widget -->
  <Features
    id="services"
    tagline="SERVICES"
    title="What We Build"
    subtitle="From web design to ERP implementation, we deliver fast, reliable, and professional services."
    items={[
      {
        title: 'Web Design',
        description: 'Bold, functional websites that convert visitors into customers.',
        icon: 'tabler:palette',
      },
      {
        title: 'Full Stack Development',
        description: 'End-to-end applications with React, Vue, Next.js, and Node.js.',
        icon: 'tabler:code',
      },
      {
        title: 'ERP Implementation',
        description: 'Enterprise resource planning systems deployed and customized.',
        icon: 'tabler:settings-automation',
      },
      {
        title: 'ERP Consulting',
        description: 'Strategic guidance to maximize your ERP investment.',
        icon: 'tabler:briefcase',
      },
      {
        title: 'Data Science',
        description: 'Advanced analytics, machine learning, and predictive modeling.',
        icon: 'tabler:chart-bar',
      },
      {
        title: 'Integration & APIs',
        description: 'Connect systems and automate workflows seamlessly.',
        icon: 'tabler:plug',
      },
    ]}
  />

  <!-- Content Widget -->
  <Content
    isReversed
    tagline="WHY US"
    title="Your Dedicated Tech Partner"
    items={[
      {
        title: 'Predictable Pricing',
        description: 'Fixed monthly rates. No surprises. Unlimited requests.',
      },
      {
        title: 'Fast Turnaround',
        description: 'Most requests completed in 2-3 business days.',
      },
      {
        title: 'Senior Expertise',
        description: 'Work with experienced developers who understand enterprise needs.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Team collaboration',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2 font-heading">Built for Growth</h3>
      Scale your tech capabilities without the overhead of hiring.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-seagreen/10 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget -->
  <Steps
    title="How It Works"
    items={[
      {
        title: '01. <span class="font-bold">Subscribe</span>',
        description: 'Choose a plan. Cancel or pause anytime.',
        icon: 'tabler:credit-card',
      },
      {
        title: '02. <span class="font-bold">Request</span>',
        description: 'Submit your requests. We handle one at a time with focus.',
        icon: 'tabler:list-check',
      },
      {
        title: '03. <span class="font-bold">Review</span>',
        description: 'Receive work within days. Revise until satisfied.',
        icon: 'tabler:eye',
      },
      {
        title: '04. <span class="font-bold">Repeat</span>',
        description: 'Keep requests coming. We are your dedicated team.',
        icon: 'tabler:refresh',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1616198814651-e71f960c3180?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=987&q=80',
      alt: 'Process steps',
    }}
  />

  <!-- Stats Widget -->
  <Stats
    stats={[
      { title: 'Projects', amount: '150+' },
      { title: 'Clients', amount: '50+' },
      { title: 'Years', amount: '8+' },
      { title: 'Technologies', amount: '25+' },
    ]}
  />

  <!-- FAQs Widget -->
  <FAQs
    title="FAQ"
    subtitle="Common questions answered"
    tagline="QUESTIONS"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'How does the subscription work?',
        description: 'Choose a plan, submit unlimited requests. We work on them one at a time. Predictable costs, no surprises.',
      },
      {
        title: 'What if I am not satisfied?',
        description: 'Unlimited revisions until you are 100% happy. Your satisfaction is guaranteed.',
      },
      {
        title: 'How fast is delivery?',
        description: 'Most requests completed in 2-3 business days. Complex projects may take longer.',
      },
      {
        title: 'Can I pause or cancel?',
        description: 'Yes. Pause when you need a break, cancel anytime. No questions asked.',
      },
    ]}
  />

  <!-- CallToAction Widget -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Start Building →',
        href: '/contact',
      },
    ]}
  >
    <Fragment slot="title">
      Ready to Build?
    </Fragment>

    <Fragment slot="subtitle">
      Get started today. No commitment required.
    </Fragment>
  </CallToAction>
</Layout>
