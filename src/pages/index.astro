---
import Layout from '~/layouts/PageLayout.astro';

import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Button from '~/components/ui/Button.astro';

const metadata = {
  title: 'Charis Systems — Expert Tech Solutions on Demand',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Custom Hero with 3D Rubik's Cube Animation -->
  <section class="relative md:-mt-[76px] not-prose min-h-screen overflow-hidden">
    <!-- Background gradient -->
    <div class="absolute inset-0 bg-gradient-to-br from-slate-50 via-indigo-50/30 to-purple-50/20 dark:from-slate-900 dark:via-indigo-950/30 dark:to-purple-950/20"></div>
    
    <!-- Three.js Rubik's Cube Container - full screen background -->
    <div id="rubiks-cube-container" class="absolute inset-0 w-full h-full pointer-events-none" aria-hidden="true"></div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 min-h-screen flex items-center">
      <div class="pt-0 md:pt-[76px]"></div>
      <div class="py-12 md:py-20 lg:py-0 w-full">
        <!-- Text content - positioned to the left -->
        <div class="max-w-2xl text-left pb-10 md:pb-16 lg:pb-0">
          <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold leading-tighter tracking-tighter mb-4 sm:mb-6 font-heading dark:text-gray-200">
            <span class="text-primary">Expert Tech</span><br />
            Solutions on Demand
          </h1>
          <p class="text-lg sm:text-xl text-muted mb-6 sm:mb-8 dark:text-slate-300 max-w-xl">
            Web design, development, ERP implementation, and consulting — all with 
            <span class="font-bold text-accent">predictable monthly pricing</span> and unlimited requests.
            No hiring headaches. No long-term commitments.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 sm:gap-4">
            <Button variant="primary" text="Get Started" href="/contact" icon="tabler:arrow-right" />
            <Button text="Our Services" href="/services" />
          </div>
        </div>
      </div>
    </div>
    
    <script>
      async function initRubiksCube() {
        const container = document.getElementById('rubiks-cube-container');
        if (!container) return;

        // Check for WebGL support
        const canvas = document.createElement('canvas');
        const gl = canvas.getContext('webgl') || canvas.getContext('experimental-webgl');
        if (!gl) {
          console.warn("WebGL not supported, skipping Rubik's Cube animation");
          return;
        }

        // Dynamically import Three.js
        const THREE = await import('three');

        // Setup scene
        const scene = new THREE.Scene();
        const isMobile = window.innerWidth < 768;
        const camera = new THREE.PerspectiveCamera(isMobile ? 50 : 45, container.clientWidth / container.clientHeight, 0.1, 1000);
        
        // Position camera to show cube on the RIGHT side of the screen (opposite the text on left)
        camera.position.set(isMobile ? -8 : -12, isMobile ? 3 : 4, isMobile ? 15 : 20);
        camera.lookAt(isMobile ? 6 : 10, 0, 0);

        const renderer = new THREE.WebGLRenderer({ 
          antialias: true, 
          alpha: true,
          powerPreference: 'high-performance'
        });
        renderer.setSize(container.clientWidth, container.clientHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.setClearColor(0x000000, 0);
        
        // Detect light/dark mode for shadow adjustment
        function isDarkMode() {
          return document.documentElement.classList.contains('dark');
        }
        
        renderer.shadowMap.enabled = true;
        renderer.shadowMap.type = THREE.PCFSoftShadowMap;
        container.appendChild(renderer.domElement);

        // Lighting setup - reduce shadows in light mode
        const ambientLight = new THREE.AmbientLight(0xffffff, isDarkMode() ? 0.6 : 0.9);
        scene.add(ambientLight);

        // Directional light with reduced shadow intensity in light mode
        const directionalLight = new THREE.DirectionalLight(0xffffff, isDarkMode() ? 0.8 : 0.4);
        directionalLight.position.set(10, 20, 10);
        directionalLight.castShadow = true;
        
        // Reduced shadow map size and softer shadows in light mode
        directionalLight.shadow.mapSize.width = isDarkMode() ? 2048 : 1024;
        directionalLight.shadow.mapSize.height = isDarkMode() ? 2048 : 1024;
        directionalLight.shadow.camera.near = 0.5;
        directionalLight.shadow.camera.far = 50;
        directionalLight.shadow.camera.left = -20;
        directionalLight.shadow.camera.right = 20;
        directionalLight.shadow.camera.top = 20;
        directionalLight.shadow.camera.bottom = -20;
        directionalLight.shadow.bias = isDarkMode() ? -0.0001 : -0.0005;
        directionalLight.shadow.radius = isDarkMode() ? 1 : 3; // More blur in light mode
        scene.add(directionalLight);

        // Fill light to reduce harsh shadows
        const fillLight = new THREE.DirectionalLight(0xffffff, isDarkMode() ? 0.3 : 0.5);
        fillLight.position.set(-10, -10, -10);
        scene.add(fillLight);

        // Update lighting when theme changes
        function updateLighting() {
          const dark = isDarkMode();
          ambientLight.intensity = dark ? 0.6 : 0.9;
          directionalLight.intensity = dark ? 0.8 : 0.4;
          fillLight.intensity = dark ? 0.3 : 0.5;
        }

        // Listen for theme changes
        const themeObserver = new MutationObserver((mutations) => {
          mutations.forEach((mutation) => {
            if (mutation.attributeName === 'class') {
              updateLighting();
            }
          });
        });
        themeObserver.observe(document.documentElement, { attributes: true });

        // Rubik's Cube colors - classic arrangement
        const colors = {
          white: 0xffffff,   // Top
          yellow: 0xffff00,  // Bottom
          red: 0xff0000,     // Front
          orange: 0xff8800,  // Back
          blue: 0x0000ff,    // Right
          green: 0x00ff00    // Left
        };

        /**
         * Creates a single cubie (small cube) with colored faces for the Rubik's Cube.
         * 
         * @param x - Position on X-axis (-1: left, 0: middle, 1: right)
         * @param y - Position on Y-axis (-1: bottom, 0: middle, 1: top)
         * @param z - Position on Z-axis (-1: back, 0: middle, 1: front)
         * 
         * Face colors are assigned based on position:
         * - Right face (x=1): Blue
         * - Left face (x=-1): Green
         * - Top face (y=1): White
         * - Bottom face (y=-1): Yellow
         * - Front face (z=1): Red
         * - Back face (z=-1): Orange
         * - Interior faces (not on outer layer): Black
         */
        function createCubie(x: number, y: number, z: number) {
          const size = 0.95; // Slightly smaller for gaps between cubies
          const geometry = new THREE.BoxGeometry(size, size, size);
          
          // Materials for each face (order: right, left, top, bottom, front, back)
          const materials = [
            new THREE.MeshPhongMaterial({ color: x === 1 ? colors.blue : 0x000000 }),   // Right (blue)
            new THREE.MeshPhongMaterial({ color: x === -1 ? colors.green : 0x000000 }),  // Left (green)
            new THREE.MeshPhongMaterial({ color: y === 1 ? colors.white : 0x000000 }),   // Top (white)
            new THREE.MeshPhongMaterial({ color: y === -1 ? colors.yellow : 0x000000 }), // Bottom (yellow)
            new THREE.MeshPhongMaterial({ color: z === 1 ? colors.red : 0x000000 }),     // Front (red)
            new THREE.MeshPhongMaterial({ color: z === -1 ? colors.orange : 0x000000 })  // Back (orange)
          ];

          const cubie = new THREE.Mesh(geometry, materials);
          cubie.position.set(x, y, z);
          cubie.castShadow = true;
          cubie.receiveShadow = true;
          
          return cubie;
        }

        // Create the complete Rubik's Cube (3x3x3)
        const cubeGroup = new THREE.Group();
        const cubies: THREE.Mesh[] = [];
        
        for (let x = -1; x <= 1; x++) {
          for (let y = -1; y <= 1; y++) {
            for (let z = -1; z <= 1; z++) {
              const cubie = createCubie(x, y, z);
              cubies.push(cubie);
              cubeGroup.add(cubie);
            }
          }
        }
        
        // Position cube group to the right side
        cubeGroup.position.set(isMobile ? 6 : 10, 0, 0);
        scene.add(cubeGroup);

        // Animation state
        interface Move {
          axis: 'x' | 'y' | 'z';
          layer: number;
          direction: number;
        }

        // Animation timing constants
        const MOVE_DURATION = 200; // milliseconds between moves
        const PAUSE_DURATION = 2000; // milliseconds to pause when solved

        let animationQueue: Move[] = [];
        let isAnimating = false;
        let currentRotation = 0;
        let targetRotation = 0;
        let animatingCubies: THREE.Mesh[] = [];
        let rotationAxis: 'x' | 'y' | 'z' = 'y';
        let animationState: 'idle' | 'shuffling' | 'solving' | 'paused' = 'idle';
        let pauseTimer = 0;
        const shuffleMoves: Move[] = [];

        // Generate random moves for shuffling
        function generateShuffleMoves() {
          shuffleMoves.length = 0;
          const moveCount = 20 + Math.floor(Math.random() * 11); // 20-30 moves
          const axes: ('x' | 'y' | 'z')[] = ['x', 'y', 'z'];
          const layers = [-1, 0, 1];
          const directions = [-1, 1];

          for (let i = 0; i < moveCount; i++) {
            shuffleMoves.push({
              axis: axes[Math.floor(Math.random() * axes.length)],
              layer: layers[Math.floor(Math.random() * layers.length)],
              direction: directions[Math.floor(Math.random() * directions.length)]
            });
          }
        }

        // Get cubies in a specific layer
        function getCubiesInLayer(axis: 'x' | 'y' | 'z', layer: number): THREE.Mesh[] {
          return cubies.filter(cubie => {
            const pos = cubie.position;
            const coord = axis === 'x' ? pos.x : axis === 'y' ? pos.y : pos.z;
            return Math.abs(coord - layer) < 0.1;
          });
        }

        // Apply a move to the cube
        function applyMove(move: Move) {
          if (isAnimating) return;
          
          animatingCubies = getCubiesInLayer(move.axis, move.layer);
          rotationAxis = move.axis;
          currentRotation = 0;
          targetRotation = (Math.PI / 2) * move.direction;
          isAnimating = true;
        }

        // Update animation
        function updateAnimation() {
          if (!isAnimating) return;

          const speed = 0.12; // Smooth rotation speed
          const diff = targetRotation - currentRotation;
          
          if (Math.abs(diff) > 0.01) {
            const step = diff * speed;
            currentRotation += step;

            // Rotate cubies
            animatingCubies.forEach(cubie => {
              const tempPos = cubie.position.clone();
              
              if (rotationAxis === 'x') {
                cubie.rotateX(step);
                const oldY = tempPos.y;
                const oldZ = tempPos.z;
                tempPos.y = oldY * Math.cos(step) - oldZ * Math.sin(step);
                tempPos.z = oldY * Math.sin(step) + oldZ * Math.cos(step);
              } else if (rotationAxis === 'y') {
                cubie.rotateY(step);
                const oldX = tempPos.x;
                const oldZ = tempPos.z;
                tempPos.x = oldX * Math.cos(step) + oldZ * Math.sin(step);
                tempPos.z = -oldX * Math.sin(step) + oldZ * Math.cos(step);
              } else {
                cubie.rotateZ(step);
                const oldX = tempPos.x;
                const oldY = tempPos.y;
                tempPos.x = oldX * Math.cos(step) - oldY * Math.sin(step);
                tempPos.y = oldX * Math.sin(step) + oldY * Math.cos(step);
              }
              
              cubie.position.copy(tempPos);
            });
          } else {
            // Snap to final position
            const finalRotation = targetRotation;
            animatingCubies.forEach(cubie => {
              const axis = rotationAxis === 'x' ? 'x' : rotationAxis === 'y' ? 'y' : 'z';
              const pos = cubie.position.clone();
              
              // Round positions to prevent floating point drift
              cubie.position.x = Math.round(pos.x * 10) / 10;
              cubie.position.y = Math.round(pos.y * 10) / 10;
              cubie.position.z = Math.round(pos.z * 10) / 10;
            });
            
            isAnimating = false;
            currentRotation = 0;
            
            // Process next move in queue
            if (animationQueue.length > 0) {
              const nextMove = animationQueue.shift()!;
              setTimeout(() => applyMove(nextMove), 100);
            } else {
              // Queue is empty, transition to next state
              if (animationState === 'shuffling') {
                animationState = 'paused';
                pauseTimer = Date.now();
              } else if (animationState === 'solving') {
                animationState = 'paused';
                pauseTimer = Date.now();
              }
            }
          }
        }

        // Start the shuffle-solve cycle
        function startCycle() {
          if (animationState === 'idle' || animationState === 'paused') {
            const currentTime = Date.now();
            
            if (animationState === 'paused' && currentTime - pauseTimer < PAUSE_DURATION) {
              return; // Still in pause
            }
            
            if (animationState === 'idle') {
              // Start shuffling
              generateShuffleMoves();
              animationQueue = [...shuffleMoves];
              animationState = 'shuffling';
              
              if (animationQueue.length > 0) {
                applyMove(animationQueue.shift()!);
              }
            } else if (animationState === 'paused') {
              // Start solving (reverse the shuffle)
              const solveMoves = shuffleMoves.map(move => ({
                axis: move.axis,
                layer: move.layer,
                direction: -move.direction // Reverse direction
              })).reverse();
              
              animationQueue = solveMoves;
              animationState = 'solving';
              
              if (animationQueue.length > 0) {
                applyMove(animationQueue.shift()!);
              }
              
              // After solving, reset to idle to start the cycle again
              setTimeout(() => {
                animationState = 'idle';
              }, solveMoves.length * MOVE_DURATION + PAUSE_DURATION);
            }
          }
        }

        // Mouse interaction
        let mouseX = 0;
        let mouseY = 0;

        const handleMouseMove = (event: MouseEvent) => {
          mouseX = (event.clientX / window.innerWidth - 0.5) * 2;
          mouseY = (event.clientY / window.innerHeight - 0.5) * 2;
        };
        window.addEventListener('mousemove', handleMouseMove);

        // Intersection Observer for performance
        let isVisible = true;
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => { isVisible = entry.isIntersecting; });
        }, { threshold: 0.1 });
        observer.observe(container);

        // Handle window resize
        const handleResize = () => {
          camera.aspect = container.clientWidth / container.clientHeight;
          camera.updateProjectionMatrix();
          renderer.setSize(container.clientWidth, container.clientHeight);
        };
        window.addEventListener('resize', handleResize);

        // Animation loop
        let animationId: number;
        function animate() {
          if (isVisible) {
            // Update cube rotation animation
            updateAnimation();
            
            // Start/continue the cycle
            startCycle();
            
            // Idle rotation when not animating moves
            if (!isAnimating) {
              cubeGroup.rotation.y += 0.003;
              cubeGroup.rotation.x += 0.001;
            }

            // Subtle camera movement based on mouse
            const isMobile = window.innerWidth < 768;
            const baseX = isMobile ? -8 : -12;
            const baseY = isMobile ? 3 : 4;
            const lookAtX = isMobile ? 6 : 10;
            camera.position.x = baseX + mouseX * 2;
            camera.position.y = baseY + mouseY * 2;
            camera.lookAt(lookAtX, 0, 0);

            renderer.render(scene, camera);
          }
          animationId = requestAnimationFrame(animate);
        }

        // Start animation after a short delay
        setTimeout(() => {
          animate();
        }, 500);

        // Cleanup function
        function cleanup() {
          cancelAnimationFrame(animationId);
          observer.disconnect();
          themeObserver.disconnect();
          window.removeEventListener('resize', handleResize);
          window.removeEventListener('mousemove', handleMouseMove);
          
          // Dispose Three.js resources
          scene.traverse((object) => {
            if (object instanceof THREE.Mesh) {
              object.geometry.dispose();
              if (Array.isArray(object.material)) {
                object.material.forEach(mat => mat.dispose());
              } else if (object.material instanceof THREE.Material) {
                object.material.dispose();
              }
            }
          });
          renderer.dispose();
          
          if (container.contains(renderer.domElement)) {
            container.removeChild(renderer.domElement);
          }
        }

        window.addEventListener('beforeunload', cleanup);
        document.addEventListener('astro:before-swap', cleanup);
      }

      // Initialize on page load and after Astro navigation (View Transitions)
      function initOnLoad() {
        // Prevent double initialization
        const container = document.getElementById('rubiks-cube-container');
        if (container && container.children.length === 0) {
          initRubiksCube();
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initOnLoad);
      } else {
        initOnLoad();
      }

      // Re-initialize after Astro View Transitions navigation
      document.addEventListener('astro:page-load', initOnLoad);
    </script>
  </section>

  <!-- Features Widget -->
  <Features
    id="services"
    tagline="SERVICES"
