        description: 'Fixed monthly rates. No surprises. Unlimited requests.',
      },
      {
        title: 'Fast Turnaround',
        description: 'Most requests completed in 2-3 business days.',
      },
      {
        title: 'Senior Expertise',
        description: 'Work with experienced developers who understand enterprise needs.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Team collaboration',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2 font-heading">Built for Growth</h3>
      Scale your tech capabilities without the overhead of hiring.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-seagreen/10 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget -->
  <Steps
    title="How It Works"
    items={[
      {
        title: '01. <span class="font-bold">Subscribe</span>',
        description: 'Choose a plan. Cancel or pause anytime.',
        icon: 'tabler:credit-card',
      },
      {
        title: '02. <span class="font-bold">Request</span>',
        description: 'Submit your requests. We handle one at a time with focus.',
        icon: 'tabler:list-check',
      },
      {
        title: '03. <span class="font-bold">Review</span>',
        description: 'Receive work within days. Revise until satisfied.',
        icon: 'tabler:eye',
      },
      {
        title: '04. <span class="font-bold">Repeat</span>',
        description: 'Keep requests coming. We are your dedicated team.',
        icon: 'tabler:refresh',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1616198814651-e71f960c3180?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=987&q=80',
      alt: 'Process steps',
    }}
