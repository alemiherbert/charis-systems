---
import Layout from '~/layouts/PageLayout.astro';

import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Button from '~/components/ui/Button.astro';

const metadata = {
  title: 'Charis Systems — Expert Tech Solutions on Demand',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Custom Hero with 3D Solar System Animation -->
  <section class="relative md:-mt-[76px] not-prose h-[80vh] overflow-hidden">
    <!-- Background gradient -->
    <div class="absolute inset-0 bg-gradient-to-br from-slate-50 via-indigo-50/30 to-purple-50/20 dark:from-slate-900 dark:via-indigo-950/30 dark:to-purple-950/20"></div>
    
    <!-- Three.js Solar System Container - full screen background -->
    <div id="solar-system-container" class="absolute inset-0 w-full h-full pointer-events-none" aria-hidden="true"></div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 h-full flex items-center">
      <div class="pt-8 md:pt-[100px]"></div>
      <div class="py-8 md:py-12 lg:py-0 w-full">
        <!-- Text content - positioned to the left -->
        <div class="max-w-2xl text-left pb-0 md:pb-2 lg:pb-0">
          <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold leading-tight tracking-tight mb-3 sm:mb-4 font-heading dark:text-gray-200">
            <span class="text-primary">Expert Tech Solutions</span><br />
            on Demand
          </h1>
          <p class="text-base sm:text-lg text-muted mb-5 sm:mb-6 dark:text-slate-300 max-w-lg">
            Web design, development, ERP implementation, and consulting — all with 
            <span class="font-bold text-accent">predictable monthly pricing</span> and unlimited requests.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 sm:gap-4">
            <Button variant="primary" text="Get Started" href="/contact" icon="tabler:arrow-right" />
            <Button text="Our Services" href="/services" />
          </div>
        </div>
      </div>
    </div>
    
    <script>
      async function initSolarSystem() {
        const container = document.getElementById('solar-system-container');
        if (!container) return;

        // Check for WebGL support
        const canvas = document.createElement('canvas');
        const gl = canvas.getContext('webgl') || canvas.getContext('experimental-webgl');
        if (!gl) {
          console.warn('WebGL not supported, skipping solar system animation');
          return;
        }

        // Dynamically import Three.js
        const THREE = await import('three');

        // Setup scene
        const scene = new THREE.Scene();
        const isMobile = window.innerWidth < 768;
        const camera = new THREE.PerspectiveCamera(isMobile ? 70 : 60, container.clientWidth / container.clientHeight, 0.1, 1000);
        // Position camera to show solar system to the RIGHT of the screen (opposite the text on left)
        // The sun is at origin (0,0,0), so we need to offset the entire view to the right
        // We position camera looking from above-left, and shift lookAt to the right
        // This makes the sun appear on the right side of the viewport
        camera.position.set(isMobile ? -10 : -15, isMobile ? 10 : 12, isMobile ? 30 : 35);
        camera.lookAt(isMobile ? 15 : 20, isMobile ? -5 : -3, 0);

        const renderer = new THREE.WebGLRenderer({ 
          antialias: true, 
          alpha: true,
          powerPreference: 'high-performance'
        });
        renderer.setSize(container.clientWidth, container.clientHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.setClearColor(0x000000, 0);
        renderer.shadowMap.enabled = true;
        renderer.shadowMap.type = THREE.PCFSoftShadowMap;
        container.appendChild(renderer.domElement);

        // Add lighting for realistic 3D spheres - brighter ambient for better planet visibility
        const ambientLight = new THREE.AmbientLight(0x808080, 0.8);
        scene.add(ambientLight);

        // Point light from the sun - brighter for better illumination
        // Define offset to move solar system to the right/down and scale multiplier
        const solarSystemOffsetX = isMobile ? 50 : 120;
        const solarSystemOffsetY = isMobile ? 0 : -10; // Move down
        const solarSystemScale = isMobile ? 4 : 5; // 5x on large screens, 4x on mobile
        
        const sunLight = new THREE.PointLight(0xfff4e6, 3, 150);
        sunLight.position.set(solarSystemOffsetX, solarSystemOffsetY, 0);
        sunLight.castShadow = true;
        sunLight.shadow.mapSize.width = 1024;
        sunLight.shadow.mapSize.height = 1024;
        scene.add(sunLight);

        // Additional directional light for better planet definition - brighter
        const directionalLight = new THREE.DirectionalLight(0xffffff, 0.6);
        directionalLight.position.set(10, 20, 10);
        scene.add(directionalLight);

        // Fill light from opposite side to reduce harsh shadows
        const fillLight = new THREE.DirectionalLight(0x8888ff, 0.3);
        fillLight.position.set(-10, -5, -10);
        scene.add(fillLight);

        // Create realistic 3D Sun with layered effect
        // Inner core - bright yellow
        const sunCoreGeometry = new THREE.SphereGeometry(2.0 * solarSystemScale, 64, 64);
        const sunCoreMaterial = new THREE.MeshPhongMaterial({ 
          color: 0xffffff,
          emissive: 0xffdd00,
          emissiveIntensity: 1.0,
          shininess: 100,
          specular: 0xffffaa
        });
        const sunCore = new THREE.Mesh(sunCoreGeometry, sunCoreMaterial);
        sunCore.position.set(solarSystemOffsetX, solarSystemOffsetY, 0);
        scene.add(sunCore);

        // Sun surface layer with texture-like variation
        const sunSurfaceGeometry = new THREE.SphereGeometry(2.5 * solarSystemScale, 64, 64);
        const sunSurfaceMaterial = new THREE.MeshPhongMaterial({ 
          color: 0xffa500,
          emissive: 0xff8800,
          emissiveIntensity: 0.8,
          transparent: true,
          opacity: 0.85,
          shininess: 50,
          specular: 0xffcc00
        });
        const sunSurface = new THREE.Mesh(sunSurfaceGeometry, sunSurfaceMaterial);
        sunSurface.position.set(solarSystemOffsetX, solarSystemOffsetY, 0);
        scene.add(sunSurface);

        // Sun corona - outer glow layer 1
        const sunGlowGeometry = new THREE.SphereGeometry(3.2 * solarSystemScale, 48, 48);
        const sunGlowMaterial = new THREE.MeshBasicMaterial({ 
          color: 0xffaa00,
          transparent: true,
          opacity: 0.35
        });
        const sunGlow = new THREE.Mesh(sunGlowGeometry, sunGlowMaterial);
        sunGlow.position.set(solarSystemOffsetX, solarSystemOffsetY, 0);
        scene.add(sunGlow);

        // Sun corona - outer glow layer 2 (larger, more transparent)
        const sunGlow2Geometry = new THREE.SphereGeometry(4.0 * solarSystemScale, 32, 32);
        const sunGlow2Material = new THREE.MeshBasicMaterial({ 
          color: 0xffdd66,
          transparent: true,
          opacity: 0.2
        });
        const sunGlow2 = new THREE.Mesh(sunGlow2Geometry, sunGlow2Material);
        sunGlow2.position.set(solarSystemOffsetX, solarSystemOffsetY, 0);
        scene.add(sunGlow2);

        // Sun corona - outermost subtle glow
        const sunGlow3Geometry = new THREE.SphereGeometry(5.0 * solarSystemScale, 24, 24);
        const sunGlow3Material = new THREE.MeshBasicMaterial({ 
          color: 0xffeeaa,
          transparent: true,
          opacity: 0.1
        });
        const sunGlow3 = new THREE.Mesh(sunGlow3Geometry, sunGlow3Material);
        sunGlow3.position.set(solarSystemOffsetX, solarSystemOffsetY, 0);
        scene.add(sunGlow3);

        // Planet data with brighter colors for better visibility (scaled by solarSystemScale)
        const planetData = [
          { orbit: 5 * solarSystemScale, size: 0.4 * solarSystemScale, color: 0x9ca3ff, emissive: 0x4f46e5, speed: 1.5, angle: 0, name: 'Mercury' },
          { orbit: 7 * solarSystemScale, size: 0.6 * solarSystemScale, color: 0xc4b5fd, emissive: 0x8b5cf6, speed: 1.2, angle: 2.1, name: 'Venus' },
          { orbit: 9.5 * solarSystemScale, size: 0.7 * solarSystemScale, color: 0x60a5fa, emissive: 0x3b82f6, speed: 1.0, angle: 4.2, name: 'Earth' },
          { orbit: 12 * solarSystemScale, size: 0.5 * solarSystemScale, color: 0xfca5a5, emissive: 0xef4444, speed: 0.8, angle: 1.0, name: 'Mars' },
          { orbit: 16 * solarSystemScale, size: 1.2 * solarSystemScale, color: 0xfcd34d, emissive: 0xf59e0b, speed: 0.5, angle: 3.5, name: 'Jupiter' },
          { orbit: 20 * solarSystemScale, size: 1.0 * solarSystemScale, color: 0xd8b4fe, emissive: 0xa855f7, speed: 0.35, angle: 5.0, name: 'Saturn' },
        ];

        interface Planet {
          mesh: THREE.Mesh;
          orbit: number;
          speed: number;
          angle: number;
          baseSpeed: number;
          ring?: THREE.Mesh;
          name: string;
          originalScale: number;
          targetScale: number;
          glowMesh?: THREE.Mesh;
        }

        const planets: Planet[] = [];
        const raycaster = new THREE.Raycaster();
        const mouse = new THREE.Vector2();
        let hoveredPlanet: Planet | null = null;

        // Create planets with realistic materials
        planetData.forEach((data) => {
          // Planet with Phong material for realistic lighting - brighter settings
          const planetGeometry = new THREE.SphereGeometry(data.size, 64, 64);
          const planetMaterial = new THREE.MeshPhongMaterial({ 
            color: data.color,
            emissive: data.emissive,
            emissiveIntensity: 0.3,
            shininess: 60,
            specular: 0x666666,
          });
          const planet = new THREE.Mesh(planetGeometry, planetMaterial);
          planet.castShadow = true;
          planet.receiveShadow = true;
          scene.add(planet);

          // Add subtle glow around each planet - brighter
          const glowGeometry = new THREE.SphereGeometry(data.size * 1.2, 32, 32);
          const glowMaterial = new THREE.MeshBasicMaterial({
            color: data.color,
            transparent: true,
            opacity: 0.25,
          });
          const glowMesh = new THREE.Mesh(glowGeometry, glowMaterial);
          scene.add(glowMesh);

          const planetObj: Planet = {
            mesh: planet,
            orbit: data.orbit,
            speed: data.speed,
            baseSpeed: data.speed,
            angle: data.angle,
            name: data.name,
            originalScale: 1,
            targetScale: 1,
            glowMesh: glowMesh
          };

          // Add ring to Saturn with more detail - brighter (scaled)
          if (data.name === 'Saturn') {
            const ringGeometry = new THREE.RingGeometry(1.3 * solarSystemScale, 2.2 * solarSystemScale, 64);
            const ringMaterial = new THREE.MeshPhongMaterial({ 
              color: 0xe9d5ff,
              emissive: 0xa855f7,
              emissiveIntensity: 0.2,
              transparent: true,
              opacity: 0.8,
              side: THREE.DoubleSide,
              shininess: 30
            });
            const ring = new THREE.Mesh(ringGeometry, ringMaterial);
            ring.rotation.x = Math.PI / 3;
            ring.castShadow = true;
            planetObj.ring = ring;
            scene.add(ring);
          }

          planets.push(planetObj);
        });

        // Add stars in the background - 20% more stars for denser field
        const starGeometry = new THREE.BufferGeometry();
        const starCount = 360;
        const starPositions = new Float32Array(starCount * 3);
        const starSizes = new Float32Array(starCount);
        
        for (let i = 0; i < starCount; i++) {
          starPositions[i * 3] = (Math.random() - 0.5) * 120;
          starPositions[i * 3 + 1] = (Math.random() - 0.5) * 120;
          starPositions[i * 3 + 2] = (Math.random() - 0.5) * 120 - 30;
          starSizes[i] = Math.random() * 0.15 + 0.05;
        }
        
        starGeometry.setAttribute('position', new THREE.BufferAttribute(starPositions, 3));
        const starMaterial = new THREE.PointsMaterial({ 
          color: 0xffffff,
          size: 0.2,
          transparent: true,
          opacity: 0.6,
          sizeAttenuation: true
        });
        const stars = new THREE.Points(starGeometry, starMaterial);
        scene.add(stars);

        let animationId: number;
        let isVisible = true;
        let mouseX = 0;
        let mouseY = 0;

        // Enable pointer events for hover detection
        renderer.domElement.style.pointerEvents = 'auto';
        container.style.pointerEvents = 'auto';

        // Mouse movement for camera and hover
        const handleMouseMove = (event: MouseEvent) => {
          mouseX = (event.clientX / window.innerWidth - 0.5) * 2;
          mouseY = (event.clientY / window.innerHeight - 0.5) * 2;
          
          // Update mouse for raycasting
          const rect = renderer.domElement.getBoundingClientRect();
          mouse.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;
          mouse.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;
        };
        window.addEventListener('mousemove', handleMouseMove);

        // Intersection Observer for performance
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => { isVisible = entry.isIntersecting; });
        }, { threshold: 0.1 });
        observer.observe(container);

        // Handle window resize
        const handleResize = () => {
          camera.aspect = container.clientWidth / container.clientHeight;
          camera.updateProjectionMatrix();
          renderer.setSize(container.clientWidth, container.clientHeight);
        };
        window.addEventListener('resize', handleResize);

        // Animation loop
        function animate() {
          if (isVisible) {
            // Rotate sun layers for dynamic 3D effect
            sunCore.rotation.y += 0.008;
            sunSurface.rotation.y -= 0.004;
            sunSurface.rotation.x += 0.002;
            sunGlow.rotation.y += 0.005;
            sunGlow2.rotation.y -= 0.003;
            sunGlow3.rotation.y += 0.002;
            
            // Raycasting for hover detection
            raycaster.setFromCamera(mouse, camera);
            const planetMeshes = planets.map(p => p.mesh);
            const intersects = raycaster.intersectObjects(planetMeshes);
            
            // Reset previous hovered planet
            if (hoveredPlanet && (!intersects.length || intersects[0].object !== hoveredPlanet.mesh)) {
              hoveredPlanet.targetScale = 1;
              hoveredPlanet.speed = hoveredPlanet.baseSpeed;
              if (hoveredPlanet.glowMesh) {
                (hoveredPlanet.glowMesh.material as THREE.MeshBasicMaterial).opacity = 0.15;
              }
              hoveredPlanet = null;
              renderer.domElement.style.cursor = 'default';
            }
            
            // Handle new hover
            if (intersects.length > 0) {
              const hitPlanet = planets.find(p => p.mesh === intersects[0].object);
              if (hitPlanet && hitPlanet !== hoveredPlanet) {
                hoveredPlanet = hitPlanet;
                hoveredPlanet.targetScale = 1.3;
                hoveredPlanet.speed = hoveredPlanet.baseSpeed * 0.3; // Slow down on hover
                if (hoveredPlanet.glowMesh) {
                  (hoveredPlanet.glowMesh.material as THREE.MeshBasicMaterial).opacity = 0.4;
                }
                renderer.domElement.style.cursor = 'pointer';
              }
            }
            
            // Animate planets
            planets.forEach((planet) => {
              planet.angle += planet.speed * 0.01;
              planet.mesh.position.x = Math.cos(planet.angle) * planet.orbit + solarSystemOffsetX;
              planet.mesh.position.y = solarSystemOffsetY;
              planet.mesh.position.z = Math.sin(planet.angle) * planet.orbit;
              planet.mesh.rotation.y += 0.015;
              
              // Smooth scale animation
              const currentScale = planet.mesh.scale.x;
              const newScale = currentScale + (planet.targetScale - currentScale) * 0.1;
              planet.mesh.scale.setScalar(newScale);
              
              // Update glow position and scale
              if (planet.glowMesh) {
                planet.glowMesh.position.copy(planet.mesh.position);
                planet.glowMesh.scale.setScalar(newScale);
              }
              
              // Update Saturn's ring position and scale
              if (planet.ring) {
                planet.ring.position.copy(planet.mesh.position);
                planet.ring.scale.setScalar(newScale);
              }
            });

            // Subtle camera movement based on mouse - offset for right-side positioning
            const isMobile = window.innerWidth < 768;
            // Camera on the LEFT, looking at RIGHT to show solar system on the right side
            const baseX = isMobile ? -15 : -20;
            const baseY = isMobile ? 18 : 15;
            const lookAtX = isMobile ? 10 : 15;
            const lookAtY = isMobile ? 5 : 0;
            camera.position.x = baseX + mouseX * 3;
            camera.position.y = baseY + mouseY * 2;
            camera.lookAt(lookAtX, lookAtY, 0);

            // Rotate stars slowly
            stars.rotation.y += 0.0002;

            renderer.render(scene, camera);
          }
          animationId = requestAnimationFrame(animate);
        }

        animate();

        // Cleanup function
        function cleanup() {
          cancelAnimationFrame(animationId);
          observer.disconnect();
          window.removeEventListener('resize', handleResize);
          window.removeEventListener('mousemove', handleMouseMove);
          
          // Dispose Three.js resources
          scene.traverse((object) => {
            if (object instanceof THREE.Mesh) {
              object.geometry.dispose();
              if (object.material instanceof THREE.Material) {
                object.material.dispose();
              }
            }
          });
          renderer.dispose();
          
          if (container.contains(renderer.domElement)) {
            container.removeChild(renderer.domElement);
          }
        }

        window.addEventListener('beforeunload', cleanup);
        document.addEventListener('astro:before-swap', cleanup);
      }

      // Initialize on page load and after Astro navigation (View Transitions)
      function initOnLoad() {
        // Prevent double initialization
        const container = document.getElementById('solar-system-container');
        if (container && container.children.length === 0) {
          initSolarSystem();
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initOnLoad);
      } else {
        initOnLoad();
      }

      // Re-initialize after Astro View Transitions navigation
      document.addEventListener('astro:page-load', initOnLoad);
    </script>
  </section>

  <!-- Features Widget -->
  <Features
