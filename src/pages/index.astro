---
import Layout from '~/layouts/PageLayout.astro';

import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Button from '~/components/ui/Button.astro';

const metadata = {
  title: 'Charis Systems — Expert Tech Solutions on Demand',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Custom Hero with Amorphous Droplet Animation -->
  <section class="relative md:-mt-[76px] not-prose min-h-[80vh] overflow-hidden">
    <!-- Background gradient -->
    <div class="absolute inset-0 bg-gradient-to-br from-slate-50 via-indigo-50/30 to-purple-50/20 dark:from-slate-900 dark:via-indigo-950/30 dark:to-purple-950/20"></div>
    
    <!-- Amorphous Droplet Container - positioned to the right -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <svg id="droplet-svg" class="absolute right-0 top-1/2 -translate-y-1/2 w-[50vw] h-[80vh] md:w-[45vw] md:h-[90vh]" viewBox="0 0 400 400" preserveAspectRatio="xMidYMid slice">
        <defs>
          <linearGradient id="dropletGradient" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" style="stop-color:#6366f1;stop-opacity:0.4" />
            <stop offset="50%" style="stop-color:#8b5cf6;stop-opacity:0.3" />
            <stop offset="100%" style="stop-color:#a855f7;stop-opacity:0.2" />
          </linearGradient>
          <linearGradient id="dropletGradient2" x1="100%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" style="stop-color:#4f46e5;stop-opacity:0.3" />
            <stop offset="100%" style="stop-color:#7c3aed;stop-opacity:0.15" />
          </linearGradient>
          <filter id="glow">
            <feGaussianBlur stdDeviation="8" result="coloredBlur"/>
            <feMerge>
              <feMergeNode in="coloredBlur"/>
              <feMergeNode in="SourceGraphic"/>
            </feMerge>
          </filter>
        </defs>
        <!-- Main droplet shape -->
        <path id="droplet-main" fill="url(#dropletGradient)" filter="url(#glow)" />
        <!-- Secondary droplet for depth -->
        <path id="droplet-secondary" fill="url(#dropletGradient2)" />
      </svg>
    </div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
      <div class="pt-0 md:pt-[76px]"></div>
      <div class="py-12 md:py-20 lg:py-28">
        <!-- Text content - positioned to the left -->
        <div class="max-w-2xl text-left pb-10 md:pb-16">
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold leading-tighter tracking-tighter mb-6 font-heading dark:text-gray-200">
            <span class="text-primary">Expert Tech</span><br />
            Solutions on Demand
          </h1>
          <p class="text-xl text-muted mb-8 dark:text-slate-300 max-w-xl">
            Web design, development, ERP implementation, and consulting — all with 
            <span class="font-bold text-accent">predictable monthly pricing</span> and unlimited requests.
            No hiring headaches. No long-term commitments.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <Button variant="primary" text="Get Started" href="/contact" icon="tabler:arrow-right" />
            <Button text="Our Services" href="/services" />
          </div>
        </div>
      </div>
    </div>
    
    <script>
      function initDropletAnimation() {
        const mainDroplet = document.getElementById('droplet-main');
        const secondaryDroplet = document.getElementById('droplet-secondary');
        if (!mainDroplet || !secondaryDroplet) return;

        let animationId: number;
        let time = 0;
        let isVisible = true;

        // Generate random blob path using superellipse/organic shape
        function generateBlobPath(
          centerX: number, 
          centerY: number, 
          baseRadius: number, 
          time: number, 
          offset: number = 0
        ): string {
          const points: string[] = [];
          const numPoints = 8;
          
          for (let i = 0; i < numPoints; i++) {
            const angle = (i / numPoints) * Math.PI * 2;
            
            // Multiple sine waves for organic movement
            const wave1 = Math.sin(time * 0.8 + angle * 2 + offset) * 25;
            const wave2 = Math.sin(time * 1.2 + angle * 3 + offset * 1.5) * 15;
            const wave3 = Math.sin(time * 0.5 + angle + offset * 0.7) * 20;
            
            const radius = baseRadius + wave1 + wave2 + wave3;
            
            const x = centerX + Math.cos(angle) * radius;
            const y = centerY + Math.sin(angle) * radius;
            
            if (i === 0) {
              points.push(`M ${x} ${y}`);
            } else {
              // Use quadratic curves for smoother blob shape
              const prevAngle = ((i - 1) / numPoints) * Math.PI * 2;
              const prevWave1 = Math.sin(time * 0.8 + prevAngle * 2 + offset) * 25;
              const prevWave2 = Math.sin(time * 1.2 + prevAngle * 3 + offset * 1.5) * 15;
              const prevWave3 = Math.sin(time * 0.5 + prevAngle + offset * 0.7) * 20;
              const prevRadius = baseRadius + prevWave1 + prevWave2 + prevWave3;
              
              const midAngle = (prevAngle + angle) / 2;
              const midRadius = (prevRadius + radius) / 2 * 1.1;
              const cpX = centerX + Math.cos(midAngle) * midRadius;
              const cpY = centerY + Math.sin(midAngle) * midRadius;
              
              points.push(`Q ${cpX} ${cpY} ${x} ${y}`);
            }
          }
          
          // Close the path smoothly
          const firstAngle = 0;
          const lastAngle = ((numPoints - 1) / numPoints) * Math.PI * 2;
          const midAngle = (lastAngle + firstAngle + Math.PI * 2) / 2;
          
          const firstWave = Math.sin(time * 0.8 + offset) * 25 + Math.sin(time * 1.2 + offset * 1.5) * 15 + Math.sin(time * 0.5 + offset * 0.7) * 20;
          const lastWave = Math.sin(time * 0.8 + lastAngle * 2 + offset) * 25 + Math.sin(time * 1.2 + lastAngle * 3 + offset * 1.5) * 15 + Math.sin(time * 0.5 + lastAngle + offset * 0.7) * 20;
          
          const firstRadius = baseRadius + firstWave;
          const lastRadius = baseRadius + lastWave;
          const midRadius = (firstRadius + lastRadius) / 2 * 1.1;
          
          const cpX = centerX + Math.cos(midAngle) * midRadius;
          const cpY = centerY + Math.sin(midAngle) * midRadius;
          const endX = centerX + Math.cos(firstAngle) * firstRadius;
          const endY = centerY + Math.sin(firstAngle) * firstRadius;
          
          points.push(`Q ${cpX} ${cpY} ${endX} ${endY}`);
          points.push('Z');
          
          return points.join(' ');
        }

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => { isVisible = entry.isIntersecting; });
        }, { threshold: 0.1 });
        
        const svg = document.getElementById('droplet-svg');
        if (svg) observer.observe(svg);

        function animate() {
          if (isVisible) {
            time += 0.02;
            
            // Main droplet - larger, centered in svg
            const mainPath = generateBlobPath(200, 200, 120, time, 0);
            mainDroplet.setAttribute('d', mainPath);
            
            // Secondary droplet - slightly offset and smaller
            const secondaryPath = generateBlobPath(200, 200, 100, time, Math.PI);
            secondaryDroplet.setAttribute('d', secondaryPath);
          }
          animationId = requestAnimationFrame(animate);
        }

        animate();

        function cleanup() {
          cancelAnimationFrame(animationId);
          observer.disconnect();
        }

        window.addEventListener('beforeunload', cleanup);
        document.addEventListener('astro:before-swap', cleanup);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initDropletAnimation);
      } else {
        initDropletAnimation();
      }
    </script>
  </section>

  <!-- Features Widget -->
  <Features
    id="services"
    tagline="SERVICES"
    title="What We Build"
    subtitle="From web design to ERP implementation, we deliver fast, reliable, and professional services."
    items={[
      {
        title: 'Web Design',
        description: 'Bold, functional websites that convert visitors into customers.',
        icon: 'tabler:palette',
      },
      {
        title: 'Full Stack Development',
        description: 'End-to-end applications with React, Vue, Next.js, and Node.js.',
        icon: 'tabler:code',
      },
      {
        title: 'ERP Implementation',
        description: 'Enterprise resource planning systems deployed and customized.',
        icon: 'tabler:settings-automation',
      },
      {
        title: 'ERP Consulting',
        description: 'Strategic guidance to maximize your ERP investment.',
        icon: 'tabler:briefcase',
      },
      {
        title: 'Data Science',
        description: 'Advanced analytics, machine learning, and predictive modeling.',
        icon: 'tabler:chart-bar',
      },
      {
        title: 'Integration & APIs',
        description: 'Connect systems and automate workflows seamlessly.',
        icon: 'tabler:plug',
      },
    ]}
  />

  <!-- Content Widget -->
  <Content
    isReversed
    tagline="WHY US"
    title="Your Dedicated Tech Partner"
    items={[
      {
        title: 'Predictable Pricing',
        description: 'Fixed monthly rates. No surprises. Unlimited requests.',
      },
      {
        title: 'Fast Turnaround',
        description: 'Most requests completed in 2-3 business days.',
      },
      {
        title: 'Senior Expertise',
        description: 'Work with experienced developers who understand enterprise needs.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Team collaboration',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2 font-heading">Built for Growth</h3>
      Scale your tech capabilities without the overhead of hiring.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-seagreen/10 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget -->
  <Steps
    title="How It Works"
    items={[
      {
        title: '01. <span class="font-bold">Subscribe</span>',
        description: 'Choose a plan. Cancel or pause anytime.',
        icon: 'tabler:credit-card',
      },
      {
        title: '02. <span class="font-bold">Request</span>',
        description: 'Submit your requests. We handle one at a time with focus.',
        icon: 'tabler:list-check',
      },
      {
        title: '03. <span class="font-bold">Review</span>',
        description: 'Receive work within days. Revise until satisfied.',
        icon: 'tabler:eye',
      },
      {
        title: '04. <span class="font-bold">Repeat</span>',
        description: 'Keep requests coming. We are your dedicated team.',
        icon: 'tabler:refresh',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1616198814651-e71f960c3180?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=987&q=80',
      alt: 'Process steps',
    }}
  />

  <!-- Stats Widget -->
  <Stats
    stats={[
      { title: 'Projects', amount: '150+' },
      { title: 'Clients', amount: '50+' },
      { title: 'Years', amount: '8+' },
      { title: 'Technologies', amount: '25+' },
    ]}
  />

  <!-- FAQs Widget -->
  <FAQs
    title="FAQ"
    subtitle="Common questions answered"
    tagline="QUESTIONS"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'How does the subscription work?',
        description: 'Choose a plan, submit unlimited requests. We work on them one at a time. Predictable costs, no surprises.',
      },
      {
        title: 'What if I am not satisfied?',
        description: 'Unlimited revisions until you are 100% happy. Your satisfaction is guaranteed.',
      },
      {
        title: 'How fast is delivery?',
        description: 'Most requests completed in 2-3 business days. Complex projects may take longer.',
      },
      {
        title: 'Can I pause or cancel?',
        description: 'Yes. Pause when you need a break, cancel anytime. No questions asked.',
      },
    ]}
  />

  <!-- CallToAction Widget -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Start Building →',
        href: '/contact',
      },
    ]}
  >
    <Fragment slot="title">
      Ready to Build?
    </Fragment>

    <Fragment slot="subtitle">
      Get started today. No commitment required.
    </Fragment>
  </CallToAction>
</Layout>
